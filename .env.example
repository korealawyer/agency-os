# ============================================================
# Agency OS — 환경변수 설정 예시
# 이 파일을 복사해 '.env' 또는 '.env.local'로 저장하세요.
# ============================================================

# ──── 데이터베이스 (Supabase / PostgreSQL) ────────────────────
# Supabase 프로젝트 → Settings → Database → Connection string (Transaction pooler)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ──── NextAuth 인증 ───────────────────────────────────────────
# 터미널에서 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-random-secret-at-least-32-characters-long

# 운영 도메인 (Vercel 배포 후 실제 URL로 변경)
NEXTAUTH_URL=https://your-app.vercel.app

# ──── 네이버 API 암호화 키 ────────────────────────────────────
# 반드시 64자 HEX 문자열 (32바이트)이어야 합니다.
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-here

# ──── Upstash Redis (Rate Limiting) ──────────────────────────
# https://console.upstash.com 에서 무료 생성
# ※ 없으면 rate limiting이 비활성화됩니다 (선택사항)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ──── 기타 ────────────────────────────────────────────────────
NODE_ENV=production

# ──── AI LLM 연동 (AI 코파일럿 실제 응답) ─────────────────────
# 우선순위: Gemini > OpenAI > Mock 폴백 (하나만 입력해도 됩니다)
#
# [권장] Google Gemini — 무료 티어 제공
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
#
# [선택] OpenAI GPT-4o-mini
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
